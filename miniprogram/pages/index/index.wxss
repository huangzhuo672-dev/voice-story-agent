/* pages/index/index.wxss - 主页样式 */

.page-container {
  padding: 0 30rpx 180rpx;
  min-height: 100vh;
  box-sizing: border-box;
}

/* 顶部标题 */
.header {
  padding: 40rpx 0 30rpx;
  text-align: center;
}

.title-row {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  margin-bottom: 12rpx;
}

.moon-icon {
  font-size: 56rpx;
}

.title {
  font-size: 52rpx;
  font-weight: 800;
  background: linear-gradient(135deg, #e0c3fc 0%, #8ec5fc 100%);
  -webkit-background-clip: text;
  color: transparent;
}

.subtitle {
  font-size: 26rpx;
  color: rgba(255,255,255,0.5);
  display: block;
}

/* 卡片通用 */
.card {
  background: rgba(255,255,255,0.06);
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  border: 1rpx solid rgba(255,255,255,0.08);
}

.card-title {
  display: flex;
  align-items: center;
  gap: 12rpx;
  font-size: 32rpx;
  font-weight: 700;
  color: #e0c3fc;
  margin-bottom: 12rpx;
}

.card-icon {
  font-size: 36rpx;
}

.card-desc {
  font-size: 24rpx;
  color: rgba(255,255,255,0.45);
  display: block;
  margin-bottom: 24rpx;
}

/* 声音卡片 */
.voice-uploaded {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: rgba(102,126,234,0.15);
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
  border: 1rpx solid rgba(102,126,234,0.3);
}

.voice-info {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.voice-name {
  font-size: 28rpx;
  color: #fff;
  font-weight: 600;
}

.voice-duration {
  font-size: 22rpx;
  color: rgba(255,255,255,0.5);
}

.voice-actions {
  display: flex;
  gap: 16rpx;
}

.btn-play, .btn-delete {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
}

.btn-play {
  background: rgba(102,126,234,0.3);
}

.btn-delete {
  background: rgba(255,80,80,0.2);
}

/* 录音/上传按钮 */
.voice-actions-row {
  display: flex;
  gap: 24rpx;
  margin-top: 8rpx;
}

.action-btn {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  padding: 32rpx 16rpx;
  border-radius: 20rpx;
  border: 2rpx dashed rgba(255,255,255,0.2);
  background: rgba(255,255,255,0.03);
  transition: all 0.3s;
}

.action-btn:active {
  background: rgba(255,255,255,0.08);
  border-color: rgba(102,126,234,0.5);
}

.action-btn.recording {
  background: rgba(255,80,80,0.15);
  border-color: rgba(255,80,80,0.5);
  animation: pulse 1.5s infinite;
}

@keyframes pulse {
  0%, 100% { box-shadow: 0 0 0 0 rgba(255,80,80,0.3); }
  50% { box-shadow: 0 0 0 20rpx rgba(255,80,80,0); }
}

.action-icon {
  font-size: 56rpx;
}

.action-text {
  font-size: 26rpx;
  color: rgba(255,255,255,0.7);
}

/* 录音动画 */
.recording-animation {
  margin-top: 24rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
}

.recording-wave {
  display: flex;
  align-items: center;
  gap: 8rpx;
  height: 60rpx;
}

.wave-bar {
  width: 8rpx;
  background: #ff5050;
  border-radius: 4rpx;
  animation: wave 0.8s ease-in-out infinite;
}

.wave-bar:nth-child(1) { height: 20rpx; animation-delay: 0s; }
.wave-bar:nth-child(2) { height: 40rpx; animation-delay: 0.15s; }
.wave-bar:nth-child(3) { height: 60rpx; animation-delay: 0.3s; }
.wave-bar:nth-child(4) { height: 40rpx; animation-delay: 0.45s; }
.wave-bar:nth-child(5) { height: 20rpx; animation-delay: 0.6s; }

@keyframes wave {
  0%, 100% { transform: scaleY(0.5); }
  50% { transform: scaleY(1.2); }
}

.recording-time {
  font-size: 28rpx;
  color: #ff5050;
  font-weight: 700;
}

/* 主题标签 */
.theme-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.theme-tag {
  padding: 14rpx 28rpx;
  border-radius: 40rpx;
  font-size: 26rpx;
  background: rgba(255,255,255,0.06);
  border: 1rpx solid rgba(255,255,255,0.1);
  color: rgba(255,255,255,0.7);
  transition: all 0.3s;
}

.theme-tag.selected {
  background: linear-gradient(135deg, rgba(102,126,234,0.3), rgba(118,75,162,0.3));
  border-color: rgba(102,126,234,0.6);
  color: #e0c3fc;
  font-weight: 600;
}

.theme-tag:active {
  transform: scale(0.95);
}

/* 自定义主题输入 */
.custom-theme {
  margin-top: 8rpx;
}

.theme-input {
  width: 100%;
  padding: 20rpx 24rpx;
  border-radius: 16rpx;
  background: rgba(255,255,255,0.06);
  border: 1rpx solid rgba(255,255,255,0.1);
  color: #fff;
  font-size: 28rpx;
  box-sizing: border-box;
}

.theme-input::placeholder {
  color: rgba(255,255,255,0.3);
}

/* 故事长度 */
.length-options {
  display: flex;
  gap: 16rpx;
}

.length-btn {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
  padding: 24rpx 12rpx;
  border-radius: 16rpx;
  background: rgba(255,255,255,0.06);
  border: 1rpx solid rgba(255,255,255,0.1);
  transition: all 0.3s;
}

.length-btn.selected {
  background: linear-gradient(135deg, rgba(102,126,234,0.3), rgba(118,75,162,0.3));
  border-color: rgba(102,126,234,0.6);
}

.length-label {
  font-size: 28rpx;
  font-weight: 700;
  color: #fff;
}

.length-desc {
  font-size: 20rpx;
  color: rgba(255,255,255,0.45);
}

/* 生成按钮 */
.generate-area {
  margin: 36rpx 0;
  text-align: center;
}

.generate-btn {
  width: 100% !important;
  height: 100rpx !important;
  line-height: 100rpx !important;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%) !important;
  color: #fff !important;
  border: none !important;
  border-radius: 50rpx !important;
  font-size: 34rpx !important;
  font-weight: 700 !important;
  box-shadow: 0 12rpx 40rpx rgba(102,126,234,0.4) !important;
  letter-spacing: 4rpx;
}

.generate-btn.generating {
  background: linear-gradient(135deg, #555 0%, #333 100%) !important;
  box-shadow: none !important;
}

.generate-btn[disabled] {
  background: rgba(255,255,255,0.1) !important;
  color: rgba(255,255,255,0.3) !important;
  box-shadow: none !important;
}

.btn-loading {
  font-size: 30rpx;
}

.generate-tip {
  display: block;
  margin-top: 16rpx;
  font-size: 24rpx;
  color: rgba(255,255,255,0.35);
}

/* 生成结果 */
.result-card {
  border-color: rgba(102,126,234,0.3) !important;
}

.story-text-area {
  background: rgba(0,0,0,0.2);
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  max-height: 400rpx;
  overflow-y: auto;
}

.story-label {
  font-size: 24rpx;
  color: rgba(255,255,255,0.5);
  display: block;
  margin-bottom: 12rpx;
}

.story-text {
  font-size: 28rpx;
  color: rgba(255,255,255,0.85);
  line-height: 1.8;
}

/* 音频播放器 */
.audio-player {
  margin-top: 16rpx;
}

.player-progress {
  margin-bottom: 16rpx;
}

.time-row {
  display: flex;
  justify-content: space-between;
  font-size: 22rpx;
  color: rgba(255,255,255,0.45);
  margin-top: 4rpx;
}

.player-controls {
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 48rpx;
}

.ctrl-btn {
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.08);
}

.play-btn {
  width: 100rpx;
  height: 100rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  font-size: 48rpx;
}

/* 加载遮罩 */
.loading-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.85);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 999;
}

.loading-content {
  text-align: center;
  padding: 60rpx;
}

.loading-stars {
  margin-bottom: 40rpx;
}

.star {
  font-size: 60rpx;
  display: inline-block;
  animation: twinkle 2s ease-in-out infinite;
}

.s1 { animation-delay: 0s; }
.s2 { animation-delay: 0.5s; }
.s3 { animation-delay: 1s; }

@keyframes twinkle {
  0%, 100% { opacity: 0.3; transform: scale(0.8); }
  50% { opacity: 1; transform: scale(1.2); }
}

.loading-text {
  display: block;
  font-size: 30rpx;
  color: #e0c3fc;
  margin-bottom: 40rpx;
  font-weight: 600;
}

.loading-steps {
  text-align: left;
  display: inline-block;
}

.step {
  font-size: 26rpx;
  color: rgba(255,255,255,0.5);
  margin-bottom: 16rpx;
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.step.done {
  color: rgba(102,255,102,0.8);
}

/* API Key 弹窗 */
.apikey-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.7);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 999;
}

.apikey-dialog {
  width: 600rpx;
  background: #1a1a2e;
  border-radius: 24rpx;
  padding: 48rpx 40rpx;
  border: 1rpx solid rgba(102,126,234,0.3);
  box-shadow: 0 20rpx 60rpx rgba(0,0,0,0.5);
}

.dialog-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #e0c3fc;
  display: block;
  text-align: center;
  margin-bottom: 16rpx;
}

.dialog-desc {
  font-size: 24rpx;
  color: rgba(255,255,255,0.5);
  display: block;
  text-align: center;
  margin-bottom: 32rpx;
  white-space: pre-line;
}

.apikey-input {
  width: 100%;
  padding: 20rpx 24rpx;
  border-radius: 16rpx;
  background: rgba(255,255,255,0.08);
  border: 1rpx solid rgba(255,255,255,0.15);
  color: #fff;
  font-size: 28rpx;
  box-sizing: border-box;
  margin-bottom: 32rpx;
}

.apikey-input::placeholder {
  color: rgba(255,255,255,0.25);
}

.dialog-btns {
  display: flex;
  gap: 20rpx;
}

.dialog-btn {
  flex: 1;
  text-align: center;
  padding: 20rpx;
  border-radius: 16rpx;
  font-size: 28rpx;
  font-weight: 600;
}

.dialog-btn.cancel {
  background: rgba(255,255,255,0.08);
  color: rgba(255,255,255,0.6);
}

.dialog-btn.confirm {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
}

/* 标题栏钥匙按钮 */
.key-btn {
  font-size: 36rpx;
  padding: 8rpx;
  margin-left: 12rpx;
}

/* 上传中提示 */
.uploading-hint {
  margin-top: 20rpx;
  text-align: center;
}

.hint-text {
  font-size: 24rpx;
  color: rgba(102,126,234,0.8);
}
