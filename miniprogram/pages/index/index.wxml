<!--pages/index/index.wxml - 主页模板-->
<view class="page-container">
  <!-- 顶部标题区 -->
  <view class="header">
    <view class="title-row">
      <text class="moon-icon">🌙</text>
      <text class="title">声伴</text>
    </view>
    <text class="subtitle">用你爱的人的声音，伴你入眠</text>
  </view>

  <!-- 声音样本区 -->
  <view class="card voice-card">
    <view class="card-title">
      <text class="card-icon">🎤</text>
      <text>声音样本</text>
    </view>
    <text class="card-desc">上传或录制一段 10~30 秒的声音，用于克隆声音</text>
    
    <!-- 已上传 -->
    <view class="voice-uploaded" wx:if="{{voiceUploaded}}">
      <view class="voice-info">
        <text class="voice-name">{{voiceFileName}}</text>
        <text class="voice-duration">{{voiceDuration}}秒</text>
      </view>
      <view class="voice-actions">
        <view class="btn-play" bindtap="playVoiceSample">
          <text>{{isPlayingSample ? '⏸' : '▶️'}}</text>
        </view>
        <view class="btn-delete" bindtap="deleteVoiceSample">
          <text>🗑️</text>
        </view>
      </view>
    </view>

    <!-- 未上传 - 操作按钮 -->
    <view class="voice-actions-row" wx:else>
      <view class="action-btn record-btn {{isRecording ? 'recording' : ''}}" bindtap="toggleRecord">
        <text class="action-icon">{{isRecording ? '⏹' : '🎙️'}}</text>
        <text class="action-text">{{isRecording ? '停止录音' : '录制声音'}}</text>
      </view>
      <view class="action-btn upload-btn" bindtap="chooseVoiceFile">
        <text class="action-icon">📁</text>
        <text class="action-text">上传文件</text>
      </view>
    </view>

    <!-- 录音中动画 -->
    <view class="recording-animation" wx:if="{{isRecording}}">
      <view class="recording-wave">
        <view class="wave-bar"></view>
        <view class="wave-bar"></view>
        <view class="wave-bar"></view>
        <view class="wave-bar"></view>
        <view class="wave-bar"></view>
      </view>
      <text class="recording-time">{{recordingTime}}秒</text>
    </view>
  </view>

  <!-- 故事主题区 -->
  <view class="card theme-card">
    <view class="card-title">
      <text class="card-icon">📖</text>
      <text>故事主题</text>
    </view>
    <text class="card-desc">选择一个主题，或输入自定义主题</text>
    
    <view class="theme-tags">
      <view 
        class="theme-tag {{selectedTheme === item ? 'selected' : ''}}"
        wx:for="{{themes}}"
        wx:key="index"
        bindtap="selectTheme"
        data-theme="{{item}}"
      >
        {{item}}
      </view>
    </view>

    <view class="custom-theme">
      <input 
        class="theme-input"
        placeholder="输入自定义主题..."
        value="{{customTheme}}"
        bindinput="onCustomThemeInput"
        bindconfirm="onCustomThemeConfirm"
      />
    </view>
  </view>

  <!-- 故事长度 -->
  <view class="card length-card">
    <view class="card-title">
      <text class="card-icon">⏱️</text>
      <text>故事长度</text>
    </view>
    <view class="length-options">
      <view 
        class="length-btn {{storyLength === item.value ? 'selected' : ''}}"
        wx:for="{{lengthOptions}}"
        wx:key="value"
        bindtap="selectLength"
        data-value="{{item.value}}"
      >
        <text class="length-label">{{item.label}}</text>
        <text class="length-desc">{{item.desc}}</text>
      </view>
    </view>
  </view>

  <!-- 生成按钮 -->
  <view class="generate-area">
    <button 
      class="generate-btn {{isGenerating ? 'generating' : ''}}"
      bindtap="generateStory"
      disabled="{{isGenerating || !voiceUploaded}}"
    >
      <text wx:if="{{isGenerating}}" class="btn-loading">⏳ 生成中 {{generateProgress}}%</text>
      <text wx:else>✨ 开始生成故事</text>
    </button>
    <text class="generate-tip" wx:if="{{!voiceUploaded}}">请先上传声音样本</text>
  </view>

  <!-- 生成结果 -->
  <view class="card result-card" wx:if="{{generatedStory}}">
    <view class="card-title">
      <text class="card-icon">🎧</text>
      <text>生成完成</text>
    </view>
    
    <view class="story-text-area">
      <text class="story-label">故事内容：</text>
      <text class="story-text">{{generatedStory}}</text>
    </view>

    <view class="audio-player">
      <view class="player-progress">
        <slider 
          min="0" 
          max="{{audioDuration}}" 
          value="{{audioCurrentTime}}"
          bindchange="onSliderChange"
          activeColor="#667eea"
          backgroundColor="rgba(255,255,255,0.1)"
          block-size="20"
        />
        <view class="time-row">
          <text>{{audioCurrentTimeText}}</text>
          <text>{{audioDurationText}}</text>
        </view>
      </view>
      <view class="player-controls">
        <view class="ctrl-btn" bindtap="replayStory">
          <text>⏮️</text>
        </view>
        <view class="ctrl-btn play-btn" bindtap="togglePlayStory">
          <text>{{isPlayingStory ? '⏸️' : '▶️'}}</text>
        </view>
        <view class="ctrl-btn" bindtap="saveStory">
          <text>💾</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 加载动画遮罩 -->
  <view class="loading-mask" wx:if="{{isGenerating}}">
    <view class="loading-content">
      <view class="loading-stars">
        <text class="star s1">✨</text>
        <text class="star s2">⭐</text>
        <text class="star s3">🌟</text>
      </view>
      <text class="loading-text">{{loadingText}}</text>
      <view class="loading-steps">
        <view class="step {{currentStep >= 1 ? 'done' : ''}}">
          <text>{{currentStep > 1 ? '✅' : '🔄'}} 克隆声音中...</text>
        </view>
        <view class="step {{currentStep >= 2 ? 'done' : ''}}">
          <text>{{currentStep > 2 ? '✅' : (currentStep == 2 ? '🔄' : '⏳')}} 生成故事内容...</text>
        </view>
        <view class="step {{currentStep >= 3 ? 'done' : ''}}">
          <text>{{currentStep > 3 ? '✅' : (currentStep == 3 ? '🔄' : '⏳')}} 合成语音中...</text>
        </view>
      </view>
    </view>
  </view>
</view>
