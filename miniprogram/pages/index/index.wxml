<!-- 声伴 v2.0 首页 — 声音设计版 -->
<view class="page-container">

  <!-- API Key 弹窗 -->
  <view class="apikey-mask" wx:if="{{showApiKeyDialog}}">
    <view class="apikey-dialog">
      <text class="dialog-title">🔑 输入 DashScope API Key</text>
      <text class="dialog-desc">在 dashscope.aliyun.com 免费获取\n新用户有充足免费额度</text>
      <input class="apikey-input" placeholder="sk-xxxx" value="{{inputApiKey}}" bindinput="onApiKeyInput" password="{{false}}" />
      <view class="dialog-btns">
        <view class="dialog-btn cancel" bindtap="cancelApiKey" wx:if="{{hasApiKey}}">取消</view>
        <view class="dialog-btn confirm" bindtap="confirmApiKey">确认</view>
      </view>
    </view>
  </view>

  <!-- 顶部 -->
  <view class="header">
    <view class="title-row">
      <text class="moon-icon">🌙</text>
      <text class="title">声伴</text>
      <view class="key-btn" bindtap="showApiKeyInput">🔑</view>
    </view>
    <text class="subtitle">用你理想的声音，伴你入眠</text>
  </view>

  <!-- ==================== 1. 选择声音风格 ==================== -->
  <view class="card">
    <view class="card-title"><text class="card-icon">🎙️</text><text>选择声音风格</text></view>
    <text class="card-desc">选择你喜欢的声音，将用它为你讲故事</text>

    <view class="voice-grid">
      <view
        class="voice-card {{selectedVoiceStyle === item.id ? 'selected' : ''}}"
        wx:for="{{voiceStyles}}" wx:key="id"
        bindtap="selectVoiceStyle" data-id="{{item.id}}"
      >
        <text class="voice-emoji">
          {{item.id === 'gentle-female' ? '👩‍🦰' : ''}}
          {{item.id === 'deep-male' ? '🧔' : ''}}
          {{item.id === 'warm-elder' ? '👵' : ''}}
          {{item.id === 'clear-youth' ? '🧑' : ''}}
          {{item.id === 'sweet-girl' ? '👧' : ''}}
          {{item.id === 'calm-neutral' ? '🎧' : ''}}
        </text>
        <text class="voice-label">{{item.label}}</text>
      </view>
    </view>

    <!-- 创建声音按钮 -->
    <button
      class="create-voice-btn"
      bindtap="createVoiceNow"
      disabled="{{voiceCreating || !selectedVoiceStyle}}"
      loading="{{voiceCreating}}"
    >
      {{voiceCreating ? '创建中...' : (voiceOnline ? '✅ 音色已就绪' : '🔊 创建我的声音')}}
    </button>
    <text class="block-tip" wx:if="{{!voiceOnline && !voiceCreating}}">选择风格后，点击按钮创建音色</text>
  </view>

  <!-- ==================== 2. 故事内容 ==================== -->
  <view class="card">
    <view class="card-title"><text class="card-icon">📖</text><text>故事内容</text></view>
    <text class="card-desc">分类或自定义，想听什么就写什么</text>

    <!-- 分类标签 + 随机按钮 -->
    <view class="category-row">
      <scroll-view class="cat-scroll" scroll-x="true">
        <view
          class="cat-tag {{selectedCategory === item.id ? 'selected' : ''}}"
          wx:for="{{categories}}" wx:key="id"
          bindtap="selectCategory" data-id="{{item.id}}"
        >
          <text class="cat-label">{{item.label}}</text>
          <text class="cat-desc">{{item.desc}}</text>
        </view>
      </scroll-view>
      <view class="random-btn" bindtap="randomCategory">
        <text class="random-icon">🎲</text>
      </view>
    </view>

    <!-- 自定义描述输入 -->
    <view class="desc-input-area">
      <input
        class="desc-input"
        placeholder="描述你想听的故事，比如：一只小老鼠在森林里探险，遇到了一只会魔法的小兔子……"
        value="{{customStoryDesc}}"
        bindinput="onStoryDescInput"
        maxlength="500"
      />
    </view>
  </view>

  <!-- ==================== 3. 故事长度 ==================== -->
  <view class="card">
    <view class="card-title"><text class="card-icon">⏱️</text><text>故事长度</text></view>
    <view class="length-info">
      <text class="length-val">{{storyMinutes}} 分钟</text>
      <text class="length-hint">约 {{storyWordCount}} 字</text>
    </view>
    <slider
      class="length-slider"
      min="{{minMinutes}}"
      max="{{maxMinutes}}"
      step="1"
      value="{{storyMinutes}}"
      bindchange="onLengthChange"
      activeColor="#667eea"
      backgroundColor="rgba(255,255,255,0.1)"
      block-size="24"
    />
    <view class="length-labels">
      <text>1分</text>
      <text>10分</text>
      <text>30分</text>
      <text>60分</text>
    </view>
  </view>

  <!-- ==================== 4. 定时关闭 ==================== -->
  <view class="card timer-card">
    <view class="card-title"><text class="card-icon">⏲️</text><text>定时关闭</text></view>
    <text class="card-desc">设定时长，到时自动停止播放</text>

    <view class="timer-options">
      <view
        class="timer-btn {{timerMinutes === item.value ? 'active' : ''}}"
        wx:for="{{timerOptions}}" wx:key="value"
        bindtap="selectTimer" data-value="{{item.value}}"
      >
        {{item.label}}
      </view>
    </view>

    <!-- 倒计时条 -->
    <view class="timer-bar-wrap" wx:if="{{timerRunning}}">
      <view class="timer-bar">
        <view class="timer-bar-fill" style="width: {{timerBarPercent}}%"></view>
      </view>
      <text class="timer-remaining">{{timerDisplay}} 后停止</text>
    </view>
  </view>

  <!-- ==================== 5. 生成按钮 ==================== -->
  <view class="generate-area">
    <button
      class="generate-btn {{isGenerating ? 'generating' : ''}}"
      bindtap="onGenerate"
      disabled="{{isGenerating}}"
    >
      <text wx:if="{{isGenerating}}">⏳ 生成中 {{generateProgress}}%</text>
      <text wx:else>✨ 开始生成故事</text>
    </button>
    <text class="generate-tip" wx:if="{{!voiceOnline}}">请先选择声音风格并创建音色</text>
    <text class="generate-tip" wx:elif="{{!selectedCategory && !customStoryDesc}}">请选择分类或输入故事描述</text>
    <text class="generate-tip" wx:else>预计 30秒~2分钟，请耐心等待 ✨</text>
  </view>

  <!-- ==================== 6. 生成结果 ==================== -->
  <view class="card result-card" wx:if="{{generatedStory}}">
    <view class="card-title"><text class="card-icon">🎧</text><text>生成完成</text></view>

    <!-- 故事文本（可折叠） -->
    <view class="story-toggle" bindtap="onToggleStory">
      <text>📜 故事内容（点{{storyExpanded ? '击收起' : '击展开'}}）</text>
    </view>
    <view class="story-text-area" wx:if="{{storyExpanded}}">
      <text class="story-text">{{generatedStory}}</text>
    </view>

    <!-- 播放器 -->
    <view class="audio-player">
      <view class="player-progress">
        <slider
          min="0" max="{{audioDuration}}" value="{{audioCurrentTime}}"
          bindchange="onSliderChange"
          activeColor="#667eea"
          backgroundColor="rgba(255,255,255,0.1)"
          block-size="18"
        />
        <view class="time-row">
          <text>{{audioCurrentTimeText}}</text>
          <text>{{audioDurationText}}</text>
        </view>
      </view>
      <view class="player-controls">
        <view class="ctrl-btn" bindtap="replayStory"><text>⏮️</text></view>
        <view class="ctrl-btn play-btn" bindtap="togglePlayStory">
          <text>{{isPlayingStory ? '⏸️' : '▶️'}}</text>
        </view>
        <view class="ctrl-btn" bindtap="saveStory"><text>💾</text></view>
      </view>
      <text class="chunk-info" wx:if="{{audioChunks.length > 1}}">
        第 {{currentChunkIndex + 1}} / {{audioChunks.length}} 段
      </text>
    </view>
  </view>

  <!-- 加载遮罩 -->
  <view class="loading-mask" wx:if="{{isGenerating}}">
    <view class="loading-content">
      <view class="loading-stars">
        <text class="star s1">✨</text>
        <text class="star s2">🌟</text>
        <text class="star s3">⭐</text>
      </view>
      <text class="loading-text">{{loadingText}}</text>
      <view class="loading-steps">
        <view class="step {{currentStep >= 1 ? 'done' : ''}}">
          <text>{{currentStep > 1 ? '✅' : (currentStep == 1 ? '🔄' : '⏳')}} 创作故事内容</text>
        </view>
        <view class="step {{currentStep >= 2 ? 'done' : ''}}">
          <text>{{currentStep > 2 ? '✅' : (currentStep == 2 ? '🔄' : '⏳')}} 合成语音</text>
        </view>
        <view class="step {{currentStep >= 3 ? 'done' : ''}}">
          <text>{{currentStep > 3 ? '✅' : (currentStep == 3 ? '🔄' : '⏳')}} 准备播放</text>
        </view>
      </view>
    </view>
  </view>

</view>
