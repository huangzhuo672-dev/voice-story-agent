<!--pages/history/history.wxml - 声伴 v2.0 历史记录-->
<view class="page-container">
  <view class="header">
    <text class="title">📜 听过的故事</text>
    <text class="subtitle" wx:if="{{history.length > 0}}">共 {{history.length}} 篇</text>
  </view>

  <!-- 空状态 -->
  <view class="empty-state" wx:if="{{history.length === 0}}">
    <text class="empty-icon">📭</text>
    <text class="empty-text">还没有生成过故事</text>
    <text class="empty-tip">去首页生成一个吧～</text>
  </view>

  <!-- 历史列表 -->
  <view class="history-list" wx:else>
    <view class="history-item" wx:for="{{history}}" wx:key="id" bindtap="playHistory" data-index="{{index}}">
      <!-- 标签行 -->
      <view class="item-tags">
        <text class="tag voice-tag" wx:if="{{item.voiceStyle}}">🎙 {{item.voiceStyle}}</text>
        <text class="tag cat-tag" wx:if="{{item.category}}">{{item.category}}</text>
        <text class="tag time-tag">{{item.minutes}}分钟</text>
      </view>
      <!-- 自定义描述 -->
      <text class="item-desc" wx:if="{{item.desc}}">"{{item.desc}}"</text>
      <!-- 故事预览 -->
      <text class="item-preview">{{item.story}}</text>
      <!-- 时间 + 操作 -->
      <view class="item-footer">
        <text class="item-time">{{item.time}}</text>
        <view class="item-btns">
          <view class="item-btn" catchtap="playHistory" data-index="{{index}}"><text>▶️</text></view>
          <view class="item-btn del" catchtap="deleteHistory" data-index="{{index}}"><text>🗑️</text></view>
        </view>
      </view>
    </view>
  </view>

  <!-- 清空 -->
  <view class="clear-area" wx:if="{{history.length > 0}}">
    <button class="clear-btn" bindtap="clearAll">🗑️ 清空所有记录</button>
  </view>

  <!-- 播放弹窗 -->
  <view class="player-mask" wx:if="{{showPlayer}}" bindtap="closePlayer">
    <view class="player-modal" catchtap="">
      <view class="player-header">
        <text class="player-title">🎧 正在播放</text>
        <view class="player-close" bindtap="closePlayer">✕</view>
      </view>
      <view class="player-meta">
        <text wx:if="{{currentPlay.voiceStyle}}">🎙 {{currentPlay.voiceStyle}} · </text>
        <text wx:if="{{currentPlay.category}}">{{currentPlay.category}} · </text>
        <text>{{currentPlay.minutes}}分钟</text>
      </view>
      <text class="player-desc" wx:if="{{currentPlay.desc}}">"{{currentPlay.desc}}"</text>

      <!-- 故事文本 -->
      <scroll-view class="player-story" scroll-y="true">
        <text>{{currentPlay.fullStory}}</text>
      </scroll-view>

      <!-- 播放控制 -->
      <view class="player-controls">
        <view class="ctrl-btn" bindtap="replayCurrent"><text>⏮️</text></view>
        <view class="ctrl-btn play-btn" bindtap="toggleCurrentPlay">
          <text>{{isPlaying ? '⏸️' : '▶️'}}</text>
        </view>
        <view class="ctrl-btn" bindtap="closePlayer"><text>✕</text></view>
      </view>
      <text class="chunk-hint" wx:if="{{chunkTotal > 1}}">第 {{chunkIdx + 1}} / {{chunkTotal}} 段</text>
    </view>
  </view>
</view>
