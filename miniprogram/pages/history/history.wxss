/* history.wxss — 声伴 v2.0 */

.page-container {
  padding: 0 30rpx 180rpx;
  min-height: 100vh;
  box-sizing: border-box;
}

.header {
  padding: 40rpx 0 30rpx;
  text-align: center;
}

.title {
  font-size: 48rpx; font-weight: 800;
  background: linear-gradient(135deg, #e0c3fc 0%, #8ec5fc 100%);
  -webkit-background-clip: text;
  color: transparent; display: block; margin-bottom: 8rpx;
}

.subtitle { font-size: 26rpx; color: rgba(255,255,255,0.45); display: block; }

/* 空状态 */
.empty-state {
  display: flex; flex-direction: column; align-items: center; justify-content: center; padding-top: 200rpx;
}
.empty-icon { font-size: 120rpx; margin-bottom: 32rpx; opacity: 0.5; }
.empty-text { font-size: 32rpx; color: rgba(255,255,255,0.5); margin-bottom: 12rpx; }
.empty-tip { font-size: 26rpx; color: rgba(255,255,255,0.3); }

/* 历史列表 */
.history-list { padding-top: 16rpx; }

.history-item {
  background: rgba(255,255,255,0.06); border-radius: 20rpx; padding: 26rpx;
  margin-bottom: 18rpx; border: 1rpx solid rgba(255,255,255,0.08);
}

/* 标签行 */
.item-tags {
  display: flex; flex-wrap: wrap; gap: 10rpx; margin-bottom: 12rpx;
}
.tag {
  padding: 6rpx 16rpx; border-radius: 8rpx; font-size: 22rpx;
}
.voice-tag { background: rgba(102,126,234,0.2); color: #a0b4ff; }
.cat-tag { background: rgba(224,195,252,0.15); color: #e0c3fc; }
.time-tag { background: rgba(255,255,255,0.08); color: rgba(255,255,255,0.5); }

.item-desc {
  font-size: 24rpx; color: rgba(255,255,255,0.4); font-style: italic;
  display: block; margin-bottom: 12rpx;
}

.item-preview {
  font-size: 26rpx; color: rgba(255,255,255,0.6); line-height: 1.6;
  display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical;
  overflow: hidden; margin-bottom: 16rpx;
}

.item-footer {
  display: flex; justify-content: space-between; align-items: center;
}
.item-time { font-size: 22rpx; color: rgba(255,255,255,0.3); }
.item-btns { display: flex; gap: 12rpx; }
.item-btn {
  width: 64rpx; height: 56rpx; display: flex; align-items: center; justify-content: center;
  border-radius: 10rpx; font-size: 28rpx; background: rgba(102,126,234,0.15);
}
.item-btn.del { background: rgba(255,80,80,0.12); }

/* 清空 */
.clear-area { padding: 32rpx 0; text-align: center; }
.clear-btn {
  background: rgba(255,80,80,0.1) !important; color: #ff8080 !important;
  border: 1rpx solid rgba(255,80,80,0.2) !important;
  border-radius: 40rpx !important; font-size: 28rpx !important;
}

/* 播放弹窗 */
.player-mask {
  position: fixed; top:0; left:0; right:0; bottom:0;
  background: rgba(0,0,0,0.85); display: flex; align-items: flex-end;
  justify-content: center; z-index: 999;
}
.player-modal {
  width: 100%; background: linear-gradient(180deg, #1a1a2e, #16213e);
  border-radius: 40rpx 40rpx 0 0; padding: 40rpx 36rpx;
  padding-bottom: calc(40rpx + env(safe-area-inset-bottom));
  max-height: 85vh; box-sizing: border-box;
}
.player-header {
  display: flex; justify-content: space-between; align-items: center; margin-bottom: 16rpx;
}
.player-title { font-size: 34rpx; font-weight: 700; color: #e0c3fc; }
.player-close {
  width: 56rpx; height: 56rpx; display: flex; align-items: center; justify-content: center;
  font-size: 32rpx; color: rgba(255,255,255,0.5); background: rgba(255,255,255,0.08); border-radius: 50%;
}
.player-meta { font-size: 26rpx; color: rgba(255,255,255,0.5); margin-bottom: 8rpx; }
.player-desc {
  font-size: 24rpx; color: rgba(255,255,255,0.4); font-style: italic;
  display: block; margin-bottom: 20rpx;
}
.player-story {
  background: rgba(0,0,0,0.3); border-radius: 16rpx; padding: 24rpx;
  max-height: 350rpx; margin-bottom: 30rpx;
}
.player-story text { font-size: 27rpx; color: rgba(255,255,255,0.78); line-height: 1.8; }

.player-controls { display: flex; justify-content: center; align-items: center; gap: 48rpx; }
.ctrl-btn {
  width: 76rpx; height: 76rpx; display: flex; align-items: center; justify-content: center;
  font-size: 38rpx; border-radius: 50%; background: rgba(255,255,255,0.08);
}
.play-btn { width: 96rpx; height: 96rpx; background: linear-gradient(135deg, #667eea, #764ba2); font-size: 46rpx; }
.chunk-hint { display: block; text-align: center; font-size: 22rpx; color: rgba(255,255,255,0.3); margin-top: 16rpx; }
