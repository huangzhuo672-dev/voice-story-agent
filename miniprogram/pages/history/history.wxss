/* pages/history/history.wxss */

.page-container {
  padding: 0 30rpx 180rpx;
  min-height: 100vh;
  box-sizing: border-box;
}

.header {
  padding: 40rpx 0 30rpx;
  text-align: center;
}

.title {
  font-size: 48rpx;
  font-weight: 800;
  background: linear-gradient(135deg, #e0c3fc 0%, #8ec5fc 100%);
  -webkit-background-clip: text;
  color: transparent;
  display: block;
  margin-bottom: 8rpx;
}

.subtitle {
  font-size: 26rpx;
  color: rgba(255,255,255,0.45);
  display: block;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-top: 200rpx;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 32rpx;
  opacity: 0.5;
}

.empty-text {
  font-size: 32rpx;
  color: rgba(255,255,255,0.5);
  margin-bottom: 12rpx;
}

.empty-tip {
  font-size: 26rpx;
  color: rgba(255,255,255,0.3);
}

/* 历史列表 */
.history-list {
  padding-top: 16rpx;
}

.history-item {
  background: rgba(255,255,255,0.06);
  border-radius: 20rpx;
  padding: 28rpx;
  margin-bottom: 20rpx;
  border: 1rpx solid rgba(255,255,255,0.08);
}

.item-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.item-theme {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.theme-icon {
  font-size: 30rpx;
}

.theme-text {
  font-size: 30rpx;
  font-weight: 700;
  color: #e0c3fc;
}

.item-time {
  font-size: 22rpx;
  color: rgba(255,255,255,0.35);
}

.item-preview {
  font-size: 26rpx;
  color: rgba(255,255,255,0.6);
  line-height: 1.6;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  margin-bottom: 20rpx;
}

.item-actions {
  display: flex;
  gap: 16rpx;
}

.item-btn {
  flex: 1;
  text-align: center;
  padding: 14rpx 0;
  border-radius: 12rpx;
  font-size: 24rpx;
  background: rgba(102,126,234,0.15);
  color: #a0b4ff;
}

.item-btn.delete {
  background: rgba(255,80,80,0.12);
  color: #ff8080;
}

/* 清空按钮 */
.clear-area {
  padding: 32rpx 0;
  text-align: center;
}

.clear-btn {
  background: rgba(255,80,80,0.12) !important;
  color: #ff8080 !important;
  border: 1rpx solid rgba(255,80,80,0.25) !important;
  border-radius: 40rpx !important;
  font-size: 28rpx !important;
}

/* 播放弹窗 */
.player-mask {
  position: fixed;
  top:0; left:0; right:0; bottom:0;
  background: rgba(0,0,0,0.85);
  display: flex;
  align-items: flex-end;
  justify-content: center;
  z-index: 999;
}

.player-modal {
  width: 100%;
  background: linear-gradient(180deg, #1a1a2e 0%, #16213e 100%);
  border-radius: 40rpx 40rpx 0 0;
  padding: 40rpx 36rpx;
  padding-bottom: calc(40rpx + env(safe-area-inset-bottom));
  max-height: 85vh;
  box-sizing: border-box;
}

.player-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.player-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #e0c3fc;
}

.player-close {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  color: rgba(255,255,255,0.5);
  background: rgba(255,255,255,0.08);
  border-radius: 50%;
}

.player-theme {
  font-size: 40rpx;
  font-weight: 800;
  color: #fff;
  display: block;
  margin-bottom: 8rpx;
}

.player-time {
  font-size: 24rpx;
  color: rgba(255,255,255,0.35);
  display: block;
  margin-bottom: 28rpx;
}

.player-story-text {
  background: rgba(0,0,0,0.3);
  border-radius: 16rpx;
  padding: 24rpx;
  max-height: 400rpx;
  overflow-y: auto;
  margin-bottom: 36rpx;
}

.player-story-text text {
  font-size: 28rpx;
  color: rgba(255,255,255,0.8);
  line-height: 1.8;
}

.player-controls {
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 48rpx;
}

.ctrl-btn {
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.08);
}

.play-btn {
  width: 100rpx;
  height: 100rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  font-size: 48rpx;
}
